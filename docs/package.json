{
  "name": "termrock-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bunx --bun fumadocs-mdx",
    "dev": "bunx --bun vite dev",
    "preview": "bunx --bun vite preview",
    "types:check": "bunx --bun fumadocs-mdx && bunx --bun tsc --noEmit",
    "gen:components": "bun run scripts/gen-component-pages.ts",
    "check:components": "bun run scripts/gen-component-pages.ts --check",
    "check:snippets": "bun run scripts/check-component-snippets.ts",
    "check:catalog": "bun run scripts/check-catalog.ts",
    "finalize:site": "bun run scripts/finalize-static-site.ts",
    "check:site": "bun run scripts/check-static-site.ts",
    "build": "bun run check:components && bun run check:snippets && bunx --bun fumadocs-mdx && bun run check:catalog && bunx --bun vite build && bun run finalize:site && bun run check:site"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-start": "^1.168.28",
    "@tanstack/start-static-server-functions": "^1.167.19",
    "@vitejs/plugin-react": "^6.0.3",
    "fumadocs-core": "^16.11.5",
    "fumadocs-mdx": "^15.2.0",
    "fumadocs-ui": "^16.11.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2"
  }
}
